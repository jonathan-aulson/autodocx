{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TIBCO_BW_SIR_v1_1",
  "type": "object",
  "required": [
    "process_name",
    "source_file",
    "source_file_format",
    "hash_sha256",
    "activities",
    "transitions",
    "metadata"
  ],
  "properties": {
    "process_name": { "type": "string", "minLength": 1 },
    "project_name": { "type": "string" },
    "source_file": { "type": "string" },
    "source_file_format": { "type": "string", "enum": ["process_xml", "bwp_xml"] },
    "hash_sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "start_activity": { "type": ["string", "null"] },

    "activities": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "palette": { "type": "string" },
          "role": {
            "type": "string",
            "enum": [
              "interface.receive","interface.reply","interface.soap",
              "invoke.process","invoke.service",
              "data.jdbc","messaging.jms","transform.mapper",
              "schedule.timer","ops.log","error.throw","other"
            ]
          },
          "config": { "type": "object" },
          "element_xpath": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": { "type": "string" },
                "selector": { "type": "string" },
                "note": { "type": "string" }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },

    "transitions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "condition": { "type": "string" },
          "label": { "type": "string" },
          "is_error_path": { "type": "boolean", "default": false }
        },
        "additionalProperties": false
      }
    },

    "resources": {
      "type": "object",
      "properties": {
        "schemas": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "namespace": { "type": "string" },
              "hash_sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" }
            },
            "additionalProperties": false
          }
        },
        "wsdls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "service": { "type": "string" },
              "hash_sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" }
            },
            "additionalProperties": false
          }
        },
        "shared_vars": { "type": "array", "items": { "type": "string" } },
        "openapi": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "method": { "type": "string" },
              "operationId": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },

    "interfaces": {
      "type": "array",
      "description": "What this process exposes",
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": { "type": "string", "enum": ["REST","SOAP","JMS","Timer","Other"] },
          "endpoint": { "type": "string" },
          "method": { "type": "string" },
          "resource": { "type": "string" },
          "operation": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "invocations": {
      "type": "array",
      "description": "What this process calls",
      "items": {
        "type": "object",
        "required": ["kind","target"],
        "properties": {
          "kind": { "type": "string", "enum": ["Process","JDBC","SOAP","REST","JMS","Other"] },
          "target": { "type": "string" },
          "operation": { "type": "string" },
          "resource": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "io_summary": {
      "type": "object",
      "properties": {
        "inputs": { "type": "array", "items": { "type": "string" } },
        "outputs": { "type": "array", "items": { "type": "string" } },
        "identifiers": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },

    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "mapped_to": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "logging": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": { "type": "string" },
          "message_hint": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "dependencies": {
      "type": "object",
      "properties": {
        "processes": { "type": "array", "items": { "type": "string" } },
        "services": { "type": "array", "items": { "type": "string" } },
        "datastores": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },

    "metadata": {
      "type": "object",
      "required": ["extracted_at", "tool_version"],
      "properties": {
        "extracted_at": { "type": "string" },
        "tool_version": { "type": "string" },
        "bw_version": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },

    "validation": {
      "type": "object",
      "properties": {
        "transition_endpoints_ok": { "type": "boolean" },
        "cycles_detected": { "type": "boolean" },
        "dangling_activities": { "type": "array", "items": { "type": "string" } },
        "unknown_activity_types": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },

    "enrichment": { "type": "object", "additionalProperties": true }
  },
  "additionalProperties": false
}
