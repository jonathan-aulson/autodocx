{
  "name": "bdddemo",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "cypress:run:login:page": "cypress run --spec 'cypress/e2e/**/LoginPage.feature' --reporter mocha-junit-reporter --reporter-options configFile=reporter-config.json",
    "cypress:run:all": "cypress run --spec 'cypress/e2e/**/*.feature'",
    "cypress:run:all:headed:chrome": "cypress run --headed --browser chrome --spec 'cypress/e2e/**/*.feature'  --browser electron --headed",
    "cypress:run:MultipleInvoices": "cypress run --spec 'cypress/e2e/**/MultipleInvoices.feature' --browser electron --headed",
    "cypress:run:BillingType": "npx cypress run --spec 'cypress/e2e/**/BillingType.feature' --browser electron --headed",
    "cypress:run:PerLabourHour": "npx cypress run --spec 'cypress/e2e/**/PerLaborHour.feature' --browser electron --headed",
    "cypress:run:FixedFee": "npx cypress run --spec 'cypress/e2e/**/FixedFee.feature' --browser electron --headed",
    "cypress:run:AdditionalFeesAndLineItems": "npx cypress run --spec 'cypress/e2e/**/AdditionalFeesAndLineItems.feature' --browser electron --headed",
    "report:run": "node cucumber-html-report.js",
    "k6:build": "cd k6 && npx webpack --config webpack.config.js",
    "k6:clean": "cd k6 && npx rimraf dist",
    "k6:auth": "cd k6 && npx ts-node src/scripts/authenticate.ts",
    "k6:auth:visible": "cd k6 && npx ts-node src/scripts/authenticate.ts --no-headless",
    "k6:auth:force": "cd k6 && npx ts-node k6/src/scripts/authenticate.ts --force",
    "k6:dev:forecast:dashboard": "cd k6 && npx ts-node run-k6.ts src/env/dev.env --output dashboard --test-file stress",
    "k6:dev:forecast:html-only": "cd k6 && npx ts-node run-k6.ts src/env/dev.env --output html-only --test-file stress",
    "k6:dev:forecast:web": "cd k6 && npx ts-node run-k6.ts src/env/dev.env --output web --test-file stress",
    "k6:uat:forecast:dashboard": "cd k6 && npx ts-node run-k6.ts src/env/uat.env --output dashboard --test-file stress",
    "k6:uat:forecast:html-only": "cd k6 && npx ts-node run-k6.ts src/env/uat.env --output html-only --test-file stress",
    "k6:uat:forecast:web": "cd k6 && npx ts-node run-k6.ts src/env/uat.env --output web --test-file stress"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "rimraf": "^5.0.1",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.3",
    "@badeball/cypress-cucumber-preprocessor": "^22.1.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.0",
    "@cypress/xpath": "^2.0.3",
    "@types/node": "^24.1.0",
    "@types/puppeteer": "^5.4.7",
    "cross-env": "^7.0.3",
    "cypress": "^13.17.0",
    "cypress-multi-reporters": "^1.6.4",
    "cypress-xpath": "^2.0.1",
    "dotenv": "^17.2.0",
    "dotenv-cli": "^9.0.0",
    "esbuild": "^0.25.5",
    "faker": "^5.5.3",
    "mocha-multi-reporters": "^1.5.1",
    "multiple-cucumber-html-reporter": "^3.9.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "@types/k6": "^0.46.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "puppeteer": "^21.0.0",
    "ts-loader": "^9.4.4",
    "tsconfig-paths": "^4.2.0",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "cypress-real-events": "^1.13.0",
    "npm": "^11.1.0",
    "puppeteer": "^24.14.0"
  },
  "lint-staged": {
    "k6/src/**/*.{ts,js}": [
      "cd k6 && npm run lint:fix",
      "cd k6 && npm run type-check"
    ]
  },
  "cypress-cucumber-preprocessor": {
    "nonGlobalStepDefinitions": true,
    "json": {
      "enabled": true,
      "generate": true,
      "output": "cypress/cucumber-json/report.json",
      "formater": "cucumber-json-formatter.exe"
    },
    "messages": {
      "enabled": true,
      "output": "cypress/cucumber-json/cucumber-messages.ndjson"
    }
  }
}
