OPENAI_API_KEY=<YOUR_API_KEY>

# Repository + pipeline roots
AUTODOCX_REPO_ROOT=.
AUTODOCX_OUT_DIR=out

# LLM + embeddings
AUTODOCX_LLM_PROVIDER=openai
AUTODOCX_LLM_MODEL=gpt-5-mini-2025-08-07
AUTODOCX_LLM_MAX_OUTPUT_TOKENS=30000
# AUTODOCX_LLM_TEMPERATURE=0
AUTODOCX_SECTION_MIN_WORDS=50
AUTODOCX_EMBED_PROVIDER=openai
AUTODOCX_EMBED_MODEL=text-embedding-3-large

# Qdrant / embeddings persistence
# AUTODOCX_QDRANT_URL=
# AUTODOCX_QDRANT_API_KEY=
# AUTODOCX_QDRANT_COLLECTION=
# AUTODOCX_QDRANT_EMBED_TOP_K=

# Pipeline switches 
AUTODOCX_PIPELINE_BUILD_CANDIDATES=true
AUTODOCX_PIPELINE_QC_CANDIDATES=true
AUTODOCX_PIPELINE_ENRICH_INDEX=true
AUTODOCX_PIPELINE_PUSH_QDRANT=false
AUTODOCX_PIPELINE_AUTO_ANCHOR_FALLBACK=true
AUTODOCX_PIPELINE_GUARD_APPEND_ONLY=true
AUTODOCX_PIPELINE_REQUIRE_DOC_HINTS=true
AUTODOCX_PIPELINE_INCLUDE_ARCHIVES=true
AUTODOCX_PIPELINE_DOC_PLAN_REFRESH=true
AUTODOCX_PIPELINE_DOC_PLAN_FULFILL=true
AUTODOCX_PIPELINE_RAG_DOCS=true
AUTODOCX_PIPELINE_LLM_ROLLUP=true
